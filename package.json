{
  "name": "ekong-coffee",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "vite --config apps/frontend/vite.config.ts",
    "dev:backend": "tsx watch apps/backend/src/index.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "tsc -p apps/frontend/tsconfig.app.json && vite build --config apps/frontend/vite.config.ts",
    "build:backend": "tsc -p apps/backend/tsconfig.json",
    "lint": "eslint apps",
    "preview": "vite preview --config apps/frontend/vite.config.ts",
    "start": "tsx apps/backend/src/index.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
